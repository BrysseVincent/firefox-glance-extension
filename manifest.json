{
  "manifest_version": 3,
  "name": "Glance",
  "version": "1.0.0",
  "description": "Alt+click a link to preview it in a floating split-screen panel instead of leaving the page.",

  "browser_specific_settings": {
    "gecko": {
      "id": "glance@brysse.dev",
      "strict_min_version": "109.0"
    }
  },

  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },

  "action": {
    "default_title": "Glance",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48": "icons/icon.svg"
    }
  },

  "background": {
    "scripts": ["background.js"]
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],

  "permissions": ["storage", "webNavigation", "bookmarks"],
  "host_permissions": ["<all_urls>"]
}
